LEXWARE_OFFICE_API_KEY=your_api_key_here

# --- v2 server: HTTP transport + GitHub OAuth (optional) ---
# Set MCP_TRANSPORT=http to run the v2 server (lexware-office-v2) as an HTTP server
# instead of stdio. Requires a GitHub OAuth App (github.com/settings/developers) whose
# "Authorization callback URL" is set to <MCP_PUBLIC_URL>/callback/github.
MCP_TRANSPORT=http
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
# Externally reachable base URL of this server (used to build the OAuth issuer,
# redirect URIs, and the GitHub callback URL). Must use https in production.
MCP_PUBLIC_URL=http://localhost:3000
# Comma-separated list of extra Host headers to accept, needed if MCP_HTTP_HOST is not
# 127.0.0.1/localhost (e.g. behind a reverse proxy).
# MCP_HTTP_ALLOWED_HOSTS=mcp.example.com

GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# GITHUB_OAUTH_SCOPE=read:user
# Comma-separated GitHub usernames allowed to log in; if unset, any GitHub account can authenticate.
# GITHUB_ALLOWED_LOGINS=octocat,someoneelse
